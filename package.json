{
  "name": "n8n-nodes-ngrave",
  "version": "1.0.0",
  "description": "A comprehensive n8n community node for NGRAVE ZERO hardware wallet integration providing 25 resources and 150+ operations for air-gapped cryptocurrency signing, PSBT workflows, multi-chain support, and GRAPHENE backup verification.",
  "license": "BUSL-1.1",
  "author": {
    "name": "Velocity BPA",
    "email": "licensing@velobpa.com",
    "url": "https://velobpa.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Velocity-BPA/n8n-nodes-ngrave.git"
  },
  "homepage": "https://github.com/Velocity-BPA/n8n-nodes-ngrave#readme",
  "bugs": {
    "url": "https://github.com/Velocity-BPA/n8n-nodes-ngrave/issues"
  },
  "main": "dist/nodes/NGrave/NGrave.node.js",
  "keywords": [
    "n8n",
    "n8n-community-node-package",
    "ngrave",
    "ngrave-zero",
    "hardware-wallet",
    "air-gapped",
    "cryptocurrency",
    "bitcoin",
    "ethereum",
    "psbt",
    "graphene",
    "liquid",
    "cold-storage",
    "multi-chain",
    "signing",
    "qr-code",
    "eal7",
    "secure-element"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/NGraveZero.credentials.js",
      "dist/credentials/NGraveLiquid.credentials.js",
      "dist/credentials/NGraveNetwork.credentials.js"
    ],
    "nodes": [
      "dist/nodes/NGrave/NGrave.node.js",
      "dist/nodes/NGrave/NGraveTrigger.node.js"
    ]
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "clean": "rimraf dist",
    "prebuild": "npm run clean",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@ngraveio/bc-ur": "^1.1.12",
    "bitcoinjs-lib": "^6.1.5",
    "bip32": "^4.0.0",
    "bip39": "^3.1.0",
    "ecpair": "^2.1.0",
    "tiny-secp256k1": "^2.2.3",
    "ethers": "^6.11.1",
    "@solana/web3.js": "^1.91.1",
    "qrcode": "^1.5.3",
    "jsqr": "^1.4.0",
    "cbor": "^9.0.2",
    "bs58": "^5.0.0",
    "bs58check": "^3.0.1",
    "bech32": "^2.0.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/bip32": "^2.0.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.25",
    "@types/qrcode": "^1.5.5",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^7.2.0",
    "@typescript-eslint/parser": "^7.2.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.1",
    "gulp": "^4.0.2",
    "jest": "^29.7.0",
    "n8n-workflow": "^1.30.0",
    "prettier": "^3.2.5",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.2"
  },
  "peerDependencies": {
    "n8n-workflow": ">=1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
